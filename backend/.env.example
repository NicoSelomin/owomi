# ============================================================
# OWOMI Backend — Variables d'environnement (exemple)
# Copier ce fichier en `.env` et renseigner les valeurs réelles.
# Ne JAMAIS committer le fichier `.env` (cf. .gitignore).
# ============================================================

# --- Base de données PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/owomi_db
DB_USERNAME=owomi_user
DB_PASSWORD=owomi_dev_password

# --- JWT ---
# Secret d'au moins 256 bits, encodé en Base64. Générer avec :
#   openssl rand -base64 48
JWT_SECRET=changeme_generate_a_strong_256_bit_base64_secret
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# --- CORS ---
# Origines autorisées (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Email SMTP (serveur transactionnel) ---
MAIL_HOST=mail.exemple.com
MAIL_PORT=587
MAIL_USERNAME=noreply@exemple.com
MAIL_PASSWORD=changeme_smtp_password
MAIL_FROM=noreply@exemple.com
MAIL_FROM_NAME=OWOMI

# --- Frontend ---
# URL publique du frontend : base des liens contenus dans les emails
# (vérification d'adresse, réinitialisation de mot de passe)
APP_FRONTEND_URL=http://localhost:4200

# --- Profil Spring & application ---
# dev | prod
SPRING_PROFILES_ACTIVE=dev

# --- Swagger ---
# true en dev, false en production
SWAGGER_ENABLED=true
